datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  full_name              String?
  phone                  String?
  role                   String    @default("user") // superadmin, admin, mosque_admin, pengurus, user, jamaah
  current_mosque_id      String?
  reset_password_token   String?
  reset_password_expires DateTime?
  two_factor_secret      String?   // Secret untuk TOTP (Google Authenticator)
  two_factor_enabled     Boolean   @default(false)
  two_factor_method      String?   @default("totp") // totp, whatsapp, sms
  otp_code               String?   // OTP sementara untuk WA/SMS
  otp_expires            DateTime? // Waktu expired OTP
  created_at             DateTime  @default(now())
}

model RolePermission {
  id          String   @id @default(uuid())
  role_name   String   @unique // superadmin, mosque_admin, pengurus, user, jamaah
  permissions String   @default("{}") // JSON string: { "menu_key": { "view": true, "edit": false, "delete": false } }
  updatedAt   DateTime @updatedAt
}

model Mosque {
  id                String   @id @default(uuid())
  name              String
  slug              String?  @unique
  address           String?
  description       String?
  logo_url          String?
  bank_name         String?
  bank_account      String?
  bank_account_name String?
  show_financial    Boolean  @default(true)
  status            String   @default("active") // active, inactive
  email             String?
  phone             String?
  city              String?
  province          String?
  about             String?
  established_year  String?
  cover_image_url   String?
  custom_domain     String?
  instagram         String?
  facebook          String?
  youtube           String?
  primary_color     String?
  timezone          String?   @default("Asia/Jakarta")
  midtrans_server_key  String?
  midtrans_client_key  String?
  midtrans_environment String? @default("sandbox")
  tv_show_finance    Boolean  @default(true)
  tv_show_jumat      Boolean  @default(true)
  tv_show_activities Boolean  @default(true)
  tv_show_announcements Boolean @default(true)
  tv_show_qrcode     Boolean  @default(true)
  tv_slideshow_urls  String?
  tv_video_url       String?
  tv_prayer_overlay_text String? @default("Mohon matikan handphone. Luruskan dan rapatkan shaf.")
  tv_prayer_overlay_duration Int @default(15)
  tv_background_url  String?  // Foto background layar TV (opsional)
  subscription_plan   String?  @default("trial")   // trial, basic, pro, enterprise
  subscription_status String?  @default("trial")   // trial, active, expired, cancelled
  subscription_start  DateTime?
  subscription_end    DateTime?
  created_at        DateTime @default(now())
}

model MosqueMember {
  id          String   @id @default(uuid())
  user_email  String
  user_name   String?
  user_phone  String?
  phone       String?
  whatsapp    String?
  address     String?
  photo_url   String?
  birth_date  String?
  categories  String?  @default("[]") // JSON string
  mosque_id   String
  role        String   // admin_masjid, bendahara, pengurus, jamaah
  status      String   @default("active")
  join_date   String?
  createdAt   DateTime @default(now())
}

model Transaction {
  id          String   @id @default(uuid())
  mosque_id   String
  type        String   // income, expense
  amount      Float
  category    String?
  description String?
  date        String   // Storing as YYYY-MM-DD strings often used in UI
  receipt_url String?  // URL bukti struk/nota
  source      String?  // manual, telegram_bot, etc.
  createdAt   DateTime @default(now())
}

model Activity {
  id          String   @id @default(uuid())
  mosque_id   String
  title       String
  description String?
  date        String
  time        String?
  location    String?
  speaker     String?
  status      String   @default("upcoming") // upcoming, completed, cancelled
  createdAt   DateTime @default(now())
}

model Announcement {
  id           String   @id @default(uuid())
  mosque_id    String
  title        String
  content      String?
  status       String   @default("published") // published, draft
  created_date String
  createdAt    DateTime @default(now())
}

model Donation {
  id             String   @id @default(uuid())
  mosque_id      String
  amount         Float
  status         String   @default("pending") // pending, completed, rejected
  donor_name     String?
  donor_email    String?
  donor_phone    String?
  payment_method String?
  payment_proof  String?
  created_date   String
  createdAt      DateTime @default(now())
}

model PrayerTime {
  id           String   @id @default(uuid())
  mosque_id    String
  subuh        String?
  dzuhur       String?
  ashar        String?
  maghrib      String?
  isya         String?
  created_date String?
  createdAt    DateTime @default(now())
}

model JumatOfficer {
  id          String   @id @default(uuid())
  mosque_id   String
  khatib      String?
  imam        String?
  muadzin     String?
  bilal       String?
  jumat_date  String?
  createdAt   DateTime @default(now())
}

model AppSettings {
  id                    String  @id @default(uuid())
  logo                  String? // Legacy field
  name                  String? // Legacy field
  theme                 String? // Legacy field
  app_name              String? @default("MasjidKu Smart")
  app_tagline           String?
  logo_url              String?
  primary_color         String?
  hero_image_url        String?
  contact_email         String?
  contact_phone         String?
  whatsapp_number       String?
  midtrans_server_key   String?
  midtrans_client_key   String?
  midtrans_environment  String? @default("sandbox")
  gemini_api_key        String? // API Key untuk AI OCR struk
}

model TelegramSettings {
  id                    String  @id @default(uuid())
  mosque_id             String  @unique
  bot_token             String? // Token Bot dari @BotFather
  chat_id               String? // Chat ID grup/channel untuk notifikasi
  notify_transactions   Boolean @default(true)  // Notif transaksi keuangan
  notify_activities     Boolean @default(true)  // Notif kegiatan baru
  notify_announcements  Boolean @default(true)  // Notif pengumuman
  notify_donations      Boolean @default(true)  // Notif donasi masuk
  bot_enabled           Boolean @default(false) // Apakah bot aktif
  gemini_api_key        String? // API Key Gemini untuk OCR struk (opsional, override global)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PlanFeatures {
  id          String  @id @default(uuid())
  name        String? // Legacy field
  plan        String  @unique // trial, monthly, yearly
  price       Float   @default(0)
  description String?
  features    String  @default("[]") // JSON array string
  is_popular  Boolean @default(false)
  max_mosques Int     @default(-1)
  storage_gb  Int     @default(-1)
}

model Attendance {
  id             String   @id @default(uuid())
  activity_id    String
  mosque_id      String
  member_name    String
  member_email   String?
  member_phone   String?
  checked_in_at  DateTime @default(now())
  createdAt      DateTime @default(now())
}
