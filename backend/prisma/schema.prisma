generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  full_name              String?
  phone                  String?
  role                   String    @default("user")
  pin                    String?   // Gembok Keamanan Sultan
  current_mosque_id      String?
  reset_password_token   String?
  reset_password_expires DateTime?
  two_factor_secret      String?
  two_factor_enabled     Boolean   @default(false)
  created_at             DateTime  @default(now())
  otp_code               String?
  otp_expires            DateTime?
  two_factor_method      String?   @default("totp")
}

// BUKU INDUK AKTIVITAS SULTAN
model AuditLog {
  id          String   @id @default(uuid())
  mosque_id   String?
  user_id     String?
  user_name   String?
  action      String   // ADD, EDIT, DELETE
  entity      String   // User, Transaction, dll.
  entity_id   String?
  description String?
  createdAt   DateTime @default(now())
}

model RolePermission {
  id          String   @id @default(uuid())
  mosque_id   String?
  role_name   String
  permissions String   @default("{}")
  updatedAt   DateTime @updatedAt

  @@unique([mosque_id, role_name])
}

model Mosque {
  id                         String    @id @default(uuid())
  name                       String
  slug                       String?   @unique
  address                    String?   @db.Text
  description                String?   @db.Text
  logo_url                   String?
  bank_name                  String?
  bank_account               String?
  bank_account_name          String?
  show_financial             Boolean   @default(true)
  status                     String    @default("active")
  email                      String?
  phone                      String?
  city                       String?
  province                   String?
  about                      String?   @db.Text
  established_year           String?
  cover_image_url            String?
  custom_domain              String?
  instagram                  String?
  facebook                   String?
  youtube                    String?
  primary_color              String?
  timezone                   String?   @default("Asia/Jakarta")
  midtrans_server_key        String?
  midtrans_client_key        String?
  midtrans_environment       String?   @default("sandbox")
  tv_show_finance            Boolean   @default(true)
  tv_show_jumat              Boolean   @default(true)
  tv_show_activities         Boolean   @default(true)
  tv_show_announcements      Boolean   @default(true)
  tv_show_qrcode             Boolean   @default(true)
  tv_live_mode               Boolean   @default(false)
  tv_slideshow_urls          String?
  tv_video_url               String?   @db.Text
  tv_prayer_overlay_text     String?   @default("Mohon matikan handphone. Luruskan dan rapatkan shaf.")
  tv_prayer_overlay_duration Int       @default(15)
  subscription_plan          String?   @default("trial")
  subscription_status        String?   @default("trial")
  subscription_start         DateTime?
  subscription_end           DateTime?
  created_at                 DateTime  @default(now())
  tv_background_url          String?
  organization_structure_url String?
  latitude                   Float?
  longitude                  Float?
  licenses                   License[]
}

model License {
  id              String   @id @default(uuid())
  key             String   @unique
  mosque_id       String
  mosque          Mosque   @relation(fields: [mosque_id], references: [id])
  domain          String?  
  status          String   @default("active") 
  expired_at      DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model Voucher {
  id              String   @id @default(uuid())
  code            String   @unique
  discount_type   String   @default("fixed") 
  discount_value  Float    @default(0)
  max_usage       Int      @default(10)
  current_usage   Int      @default(0)
  expired_at      DateTime?
  status          String   @default("active")
  created_at      DateTime @default(now())
}

model MosqueMember {
  id         String   @id @default(uuid())
  user_email String
  user_name  String?
  mosque_id  String
  role       String
  status     String   @default("active")
  join_date     String?
  membership_id   String?  @unique
  attendance_count Int      @default(0)
  createdAt        DateTime @default(now())
  user_phone String?
  address    String?   @db.Text
  birth_date String?
  categories String?  @default("[]")
  phone      String?
  photo_url  String?
  whatsapp   String?
}

model Transaction {
  id          String   @id @default(uuid())
  mosque_id   String
  type        String
  amount      Float
  category    String?
  description String?   @db.Text
  date        String
  createdAt   DateTime @default(now())
  receipt_url String?
  source      String?
}

model Activity {
  id          String   @id @default(uuid())
  mosque_id   String
  title       String
  description String?  @db.Text
  date        String
  time        String?
  location    String?
  speaker     String?
  status      String   @default("upcoming")
  createdAt   DateTime @default(now())
}

model Announcement {
  id           String   @id @default(uuid())
  mosque_id    String
  title        String
  content      String?  @db.Text
  status       String   @default("published")
  created_date String
  createdAt    DateTime @default(now())
}

model Donation {
  id             String   @id @default(uuid())
  mosque_id      String
  amount         Float
  status         String   @default("pending")
  donor_name     String?
  donor_email    String?
  donor_phone    String?
  payment_method String?
  payment_proof  String?
  category       String?  @default("Infaq")
  sub_category   String?
  created_date   String
  createdAt      DateTime @default(now())
}

model Mustahik {
  id               String   @id @default(cuid())
  mosque_id        String
  name             String
  address          String?  @db.Text
  phone            String?
  asnaf_category   String   // Fakir, Miskin, Amil, Mu'allaf, Riqab, Gharim, Fisabilillah, Ibnu Sabil
  status           String   @default("pending") // pending, verified, rejected
  notes            String?  @db.Text
  photo_url        String?
  last_aid_date    String?
  createdAt        DateTime @default(now())
  
  distributions    AidDistribution[]
}

model AidDistribution {
  id                  String   @id @default(cuid())
  mosque_id           String
  mustahik_id         String
  mustahik            Mustahik @relation(fields: [mustahik_id], references: [id], onDelete: Cascade)
  amount              Float
  source_type         String   // zakat_maal, zakat_fitrah, infaq, shodaqoh
  distribution_date   String
  description         String?
  createdAt           DateTime @default(now())
}

model QurbanAnimal {
  id               String   @id @default(cuid())
  mosque_id        String
  type             String   // Sapi, Kambing, Domba, Unta
  price            Float
  weight_approx    String?
  total_slots      Int      @default(1) // Can be 1, 7, 5, etc.
  status           String   @default("available") // available, full, slaughtered, distributed
  notes            String?
  createdAt        DateTime @default(now())
  
  participants     QurbanParticipant[]
}

model QurbanParticipant {
  id               String   @id @default(cuid())
  mosque_id        String
  animal_id        String
  animal           QurbanAnimal @relation(fields: [animal_id], references: [id], onDelete: Cascade)
  name             String
  phone            String?
  payment_status   String   @default("pending") // pending, paid
  amount_paid      Float    @default(0)
  registration_date String
  createdAt        DateTime @default(now())
}

model Asset {
  id                   String   @id @default(cuid())
  mosque_id            String
  name                 String
  category             String
  condition            String
  status               String?   @default("aktif")
  location             String?   @db.Text
  description          String?   @db.Text
  photo_url            String?
  acquisition_date     String?
  acquisition_value    Float?
  current_value        Float?
  maintenance_schedule String?
  last_maintenance     String?
  next_maintenance     String?
  maintenance_notes    String?
  qr_code_id           String?   @unique
  createdAt            DateTime @default(now())

  maintenances         AssetMaintenance[]
}

model AssetMaintenance {
  id               String   @id @default(cuid())
  asset_id         String
  asset            Asset    @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  maintenance_date String
  technician       String?
  cost             Float?    @default(0)
  description      String
  status           String?   @default("selesai") // selesai, direncanakan
  createdAt        DateTime @default(now())
}

model PrayerTime {
  id           String   @id @default(uuid())
  mosque_id    String
  subuh        String?
  dzuhur       String?
  ashar        String?
  maghrib      String?
  isya         String?
  created_date String?
  createdAt    DateTime @default(now())
}

model JumatOfficer {
  id         String   @id @default(uuid())
  mosque_id  String
  khatib     String?
  imam       String?
  muadzin    String?
  bilal      String?
  jumat_date String?
  createdAt  DateTime @default(now())
}

model AppSettings {
  id                   String  @id @default(uuid())
  logo                 String?
  name                 String?
  theme                String?
  app_name             String? @default("MasjidKu Smart")
  app_tagline          String?
  contact_email        String?
  contact_phone        String?
  hero_image_url       String?   @db.Text
  logo_url             String?
  midtrans_client_key  String?
  midtrans_environment String? @default("sandbox")
  midtrans_server_key  String?
  primary_color        String?
  whatsapp_number      String?
  gemini_api_key       String?
}

model TelegramSettings {
  id                   String   @id @default(uuid())
  mosque_id            String   @unique
  bot_token            String?
  chat_id              String?
  notify_transactions  Boolean  @default(true)
  notify_activities    Boolean  @default(true)
  notify_announcements Boolean  @default(true)
  notify_donations     Boolean  @default(true)
  bot_enabled          Boolean  @default(false)
  gemini_api_key       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PlanFeatures {
  id             String  @id @default(uuid())
  name           String?
  plan           String  @unique
  price          Float   @default(0)
  original_price Float   @default(0)
  description    String?
  features       String  @default("[]")
  is_popular     Boolean @default(false)
  max_mosques    Int     @default(-1)
  storage_gb     Int     @default(-1)
}

model Attendance {
  id            String   @id @default(uuid())
  activity_id   String
  mosque_id     String
  member_name   String
  member_email  String?
  member_phone  String?
  checked_in_at DateTime @default(now())
  createdAt     DateTime @default(now())
}
