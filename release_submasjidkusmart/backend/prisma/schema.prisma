generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  full_name              String?
  phone                  String?
  role                   String    @default("user")
  current_mosque_id      String?
  reset_password_token   String?
  reset_password_expires DateTime?
  two_factor_secret      String?
  two_factor_enabled     Boolean   @default(false)
  created_at             DateTime  @default(now())
  otp_code               String?
  otp_expires            DateTime?
  two_factor_method      String?   @default("totp")
}

model RolePermission {
  id          String   @id @default(uuid())
  role_name   String   @unique
  permissions String   @default("{}")
  updatedAt   DateTime @updatedAt
}

model Mosque {
  id                         String    @id @default(uuid())
  name                       String
  slug                       String?   @unique
  address                    String?
  description                String?
  logo_url                   String?
  bank_name                  String?
  bank_account               String?
  bank_account_name          String?
  show_financial             Boolean   @default(true)
  status                     String    @default("active")
  email                      String?
  phone                      String?
  city                       String?
  province                   String?
  about                      String?
  established_year           String?
  cover_image_url            String?
  custom_domain              String?
  instagram                  String?
  facebook                   String?
  youtube                    String?
  primary_color              String?
  timezone                   String?   @default("Asia/Jakarta")
  midtrans_server_key        String?
  midtrans_client_key        String?
  midtrans_environment       String?   @default("sandbox")
  tv_show_finance            Boolean   @default(true)
  tv_show_jumat              Boolean   @default(true)
  tv_show_activities         Boolean   @default(true)
  tv_show_announcements      Boolean   @default(true)
  tv_show_qrcode             Boolean   @default(true)
  tv_live_mode               Boolean   @default(false)
  tv_slideshow_urls          String?
  tv_video_url               String?
  tv_prayer_overlay_text     String?   @default("Mohon matikan handphone. Luruskan dan rapatkan shaf.")
  tv_prayer_overlay_duration Int       @default(15)
  subscription_plan          String?   @default("trial")
  subscription_status        String?   @default("trial")
  subscription_start         DateTime?
  subscription_end           DateTime?
  created_at                 DateTime  @default(now())
  tv_background_url          String?
  organization_structure_url String?
  latitude                   Float?
  longitude                  Float?
  licenses                   License[]
}

model License {
  id              String   @id @default(uuid())
  key             String   @unique
  mosque_id       String
  mosque          Mosque   @relation(fields: [mosque_id], references: [id])
  domain          String?  // Domain yang diizinkan (misal: masjid-raya.com)
  status          String   @default("active") // active, revoked, expired
  expired_at      DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model MosqueMember {
  id         String   @id @default(uuid())
  user_email String
  user_name  String?
  mosque_id  String
  role       String
  status     String   @default("active")
  join_date  String?
  createdAt  DateTime @default(now())
  user_phone String?
  address    String?
  birth_date String?
  categories String?  @default("[]")
  phone      String?
  photo_url  String?
  whatsapp   String?
}

model Transaction {
  id          String   @id @default(uuid())
  mosque_id   String
  type        String
  amount      Float
  category    String?
  description String?
  date        String
  createdAt   DateTime @default(now())
  receipt_url String?
  source      String?
}

model Activity {
  id          String   @id @default(uuid())
  mosque_id   String
  title       String
  description String?
  date        String
  time        String?
  location    String?
  speaker     String?
  status      String   @default("upcoming")
  createdAt   DateTime @default(now())
}

model Announcement {
  id           String   @id @default(uuid())
  mosque_id    String
  title        String
  content      String?
  status       String   @default("published")
  created_date String
  createdAt    DateTime @default(now())
}

model Donation {
  id             String   @id @default(uuid())
  mosque_id      String
  amount         Float
  status         String   @default("pending")
  donor_name     String?
  donor_email    String?
  donor_phone    String?
  payment_method String?
  payment_proof  String?
  created_date   String
  createdAt      DateTime @default(now())
}

model PrayerTime {
  id           String   @id @default(uuid())
  mosque_id    String
  subuh        String?
  dzuhur       String?
  ashar        String?
  maghrib      String?
  isya         String?
  created_date String?
  createdAt    DateTime @default(now())
}

model JumatOfficer {
  id         String   @id @default(uuid())
  mosque_id  String
  khatib     String?
  imam       String?
  muadzin    String?
  bilal      String?
  jumat_date String?
  createdAt  DateTime @default(now())
}

model AppSettings {
  id                   String  @id @default(uuid())
  logo                 String?
  name                 String?
  theme                String?
  app_name             String? @default("MasjidKu Smart")
  app_tagline          String?
  contact_email        String?
  contact_phone        String?
  hero_image_url       String?
  logo_url             String?
  midtrans_client_key  String?
  midtrans_environment String? @default("sandbox")
  midtrans_server_key  String?
  primary_color        String?
  whatsapp_number      String?
  gemini_api_key       String?
}

model TelegramSettings {
  id                   String   @id @default(uuid())
  mosque_id            String   @unique
  bot_token            String?
  chat_id              String?
  notify_transactions  Boolean  @default(true)
  notify_activities    Boolean  @default(true)
  notify_announcements Boolean  @default(true)
  notify_donations     Boolean  @default(true)
  bot_enabled          Boolean  @default(false)
  gemini_api_key       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PlanFeatures {
  id             String  @id @default(uuid())
  name           String?
  plan           String  @unique
  price          Float   @default(0)
  original_price Float   @default(0)
  description    String?
  features       String  @default("[]")
  is_popular     Boolean @default(false)
  max_mosques    Int     @default(-1)
  storage_gb     Int     @default(-1)
}

model Voucher {
  id          String   @id @default(uuid())
  code        String   @unique
  discount    Float
  type        String   @default("percentage")
  expiry_date String?
  max_uses    Int      @default(-1)
  used_count  Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
}

model Attendance {
  id            String   @id @default(uuid())
  activity_id   String
  mosque_id     String
  member_name   String
  member_email  String?
  member_phone  String?
  checked_in_at DateTime @default(now())
  createdAt     DateTime @default(now())
}
